---
import Base from '../layouts/Base.astro';
import EntryCard from '../components/EntryCard.astro';
import entriesData from '../data/entries.json';

const { categories, entries, counts, built_at } = entriesData;

// Active entries only, sorted by stars desc, then name asc.
const active = entries
  .filter((e) => e.status === 'active')
  .slice()
  .sort((a, b) => {
    const sa = a.stats?.stars ?? -1;
    const sb = b.stats?.stars ?? -1;
    if (sb !== sa) return sb - sa;
    return a.name.localeCompare(b.name);
  });

// per-category counts for the cards
const perCategory: Record<string, number> = {};
for (const c of categories) perCategory[c.id] = 0;
for (const e of active) {
  if (perCategory[e.category] !== undefined) perCategory[e.category]++;
}

// derive filter options from the active entries
const uniqueTypes = Array.from(new Set(active.map((e) => e.tags.type))).sort();
const uniquePersonas = Array.from(
  new Set(active.flatMap((e) => e.tags.personas ?? []))
).sort();

const base = import.meta.env.BASE_URL;
const catHref = (id: string) =>
  `${base.replace(/\/$/, '')}/category/${id}`;

const title = 'Marketing AI Stack — AI tools & MCPs that automate marketing work';
const description =
  'A curated list of AI tools, MCP servers, and Claude Code skills that plug into the tools marketers already use — Google Ads, GA4, Notion, HubSpot, Webflow, Mailchimp, Search Console — and automate marketing work, not just assist it.';
---

<Base title={title} description={description}>
  <section class="hero">
    <h1>Marketing AI Stack</h1>
    <p class="lede">
      AI tools, MCP servers, and Claude Code skills that plug into the tools
      marketers already use — Google Ads, GA4, Notion, HubSpot, Webflow,
      Mailchimp, Search Console — and automate marketing work, not just assist
      it.
    </p>
    <p class="counts">
      {counts.active} active
      {counts.watchlist > 0 && ` · ${counts.watchlist} watchlist`}
      {counts.archived > 0 && ` · ${counts.archived} archived`}
      {' · '}
      built {built_at}
    </p>
  </section>

  <section aria-labelledby="cats-heading">
    <h2 id="cats-heading">Categories</h2>
    <p class="section-blurb">
      Every entry lives in exactly one category. Cross-posting is not allowed —
      pick the primary job.
    </p>
    <div class="cat-grid">
      {categories.map((c) => (
        <a class="cat-card" href={catHref(c.id)}>
          <h3>{c.title}</h3>
          <p>{c.blurb}</p>
          <span class="count">
            {perCategory[c.id] ?? 0} {perCategory[c.id] === 1 ? 'entry' : 'entries'}
          </span>
        </a>
      ))}
    </div>
  </section>

  <section aria-labelledby="entries-heading">
    <h2 id="entries-heading">All active entries</h2>
    <p class="section-blurb">
      Filter by text, category, type, persona, or AI nativeness. Toggle to show
      only MCP-ready entries.
    </p>

    {active.length === 0 ? (
      <div class="empty">
        <strong>No entries yet.</strong>
        YAML entries live in <code>data/entries/</code>. Run
        <code>npm run build</code> at the repo root to generate
        <code>site/src/data/entries.json</code>, then rebuild the site.
      </div>
    ) : (
      <>
        <form class="filters" id="filters" role="search" aria-label="Filter entries">
          <label>
            Search
            <input
              type="search"
              id="f-search"
              placeholder="name, description, why it matters…"
              autocomplete="off"
              spellcheck="false"
            />
          </label>
          <label>
            Category
            <select id="f-category">
              <option value="">All</option>
              {categories.map((c) => (
                <option value={c.id}>{c.title}</option>
              ))}
            </select>
          </label>
          <label>
            Type
            <select id="f-type">
              <option value="">All</option>
              {uniqueTypes.map((t) => (
                <option value={t}>{t}</option>
              ))}
            </select>
          </label>
          <label>
            Persona
            <select id="f-persona">
              <option value="">All</option>
              {uniquePersonas.map((p) => (
                <option value={p}>{p}</option>
              ))}
            </select>
          </label>
          <label>
            AI nativeness
            <select id="f-ai">
              <option value="">All</option>
              <option value="ai-native">AI-native</option>
              <option value="ai-enabled">AI-enabled</option>
              <option value="substrate">Substrate</option>
            </select>
          </label>
          <label class="mcp-toggle">
            <input type="checkbox" id="f-mcp" />
            MCP-ready only
          </label>
        </form>

        <div class="filter-meta">
          <span id="filter-count" aria-live="polite" aria-atomic="true">
            Showing {active.length} of {active.length}
          </span>
          <button type="button" id="f-reset">Reset filters</button>
        </div>

        <div class="entries" id="entries-list">
          {active.map((e) => <EntryCard entry={e} />)}
        </div>

        <div class="empty" id="no-results" hidden>
          <strong>No entries match your filters.</strong>
          Try clearing the search box or resetting filters.
        </div>
      </>
    )}
  </section>

  <script is:inline>
    // Vanilla, no framework. Reads data-* attrs on .entry-card elements.
    (function () {
      const form = document.getElementById('filters');
      if (!form) return;

      const $search = document.getElementById('f-search');
      const $cat = document.getElementById('f-category');
      const $type = document.getElementById('f-type');
      const $persona = document.getElementById('f-persona');
      const $ai = document.getElementById('f-ai');
      const $mcp = document.getElementById('f-mcp');
      const $reset = document.getElementById('f-reset');
      const $meta = document.getElementById('filter-count');
      const $empty = document.getElementById('no-results');
      const cards = Array.from(document.querySelectorAll('[data-entry]'));
      const total = cards.length;

      function applyFilters() {
        const q = ($search.value || '').trim().toLowerCase();
        const cat = $cat.value;
        const type = $type.value;
        const persona = $persona.value;
        const ai = $ai.value;
        const mcpOnly = $mcp.checked;

        let visible = 0;
        for (const card of cards) {
          const hay = card.getAttribute('data-search') || '';
          const cCat = card.getAttribute('data-category') || '';
          const cType = card.getAttribute('data-type') || '';
          const cAi = card.getAttribute('data-ai') || '';
          const cMcp = card.getAttribute('data-mcp') === 'true';
          const cPersonas = (card.getAttribute('data-personas') || '')
            .split(',')
            .filter(Boolean);

          let ok = true;
          if (q && hay.indexOf(q) === -1) ok = false;
          if (ok && cat && cCat !== cat) ok = false;
          if (ok && type && cType !== type) ok = false;
          if (ok && ai && cAi !== ai) ok = false;
          if (ok && persona && cPersonas.indexOf(persona) === -1) ok = false;
          if (ok && mcpOnly && !cMcp) ok = false;

          if (ok) {
            card.hidden = false;
            visible++;
          } else {
            card.hidden = true;
          }
        }

        if ($meta) {
          $meta.textContent = 'Showing ' + visible + ' of ' + total;
        }
        if ($empty) {
          $empty.hidden = visible !== 0;
        }
      }

      function resetAll() {
        $search.value = '';
        $cat.value = '';
        $type.value = '';
        $persona.value = '';
        $ai.value = '';
        $mcp.checked = false;
        applyFilters();
      }

      form.addEventListener('input', applyFilters);
      form.addEventListener('change', applyFilters);
      form.addEventListener('submit', function (e) { e.preventDefault(); });
      $reset.addEventListener('click', resetAll);

      applyFilters();
    })();
  </script>
</Base>
