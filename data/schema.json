{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dapollonsky/marketing-ai-stack/blob/main/data/schema.json",
  "title": "Marketing AI Stack Entry",
  "description": "One project that belongs on the Marketing AI Stack list. Every entry must answer: what specific marketing task does this automate, and who benefits?",
  "type": "object",
  "required": [
    "name",
    "slug",
    "url",
    "repo",
    "category",
    "tags",
    "description",
    "why_it_matters",
    "closed_alternative",
    "stats",
    "submitted",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Display name"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "maxLength": 60,
      "description": "Kebab-case identifier; must match the YAML filename (without extension)"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Primary URL — product home page or main docs"
    },
    "repo": {
      "type": ["string", "null"],
      "description": "GitHub repo URL. May be null for hosted services without an open component."
    },
    "category": {
      "type": "string",
      "enum": [
        "content",
        "seo",
        "social",
        "ads",
        "email",
        "analytics",
        "research",
        "integrations"
      ]
    },
    "tags": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ai_nativeness", "mcp_ready"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "mcp",
            "aggregator",
            "agent",
            "app",
            "framework",
            "skill-pack",
            "template",
            "cms",
            "crm",
            "library"
          ]
        },
        "ai_nativeness": {
          "type": "string",
          "enum": ["ai-native", "ai-enabled", "substrate"]
        },
        "mcp_ready": {
          "type": "boolean"
        }
      }
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 280,
      "description": "One sentence: what it is"
    },
    "why_it_matters": {
      "type": "string",
      "minLength": 20,
      "maxLength": 400,
      "description": "One sentence: the specific marketing task it automates, naming persona and outcome. No adjectives, no fluff."
    },
    "closed_alternative": {
      "type": ["string", "null"],
      "maxLength": 120,
      "description": "Name of the closed-source incumbent this replaces or competes with (e.g., 'Jasper', 'Buffer', 'Mailchimp'). Null only when genuinely no incumbent exists."
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stars", "last_commit", "license"],
      "properties": {
        "stars": { "type": ["integer", "null"], "minimum": 0 },
        "last_commit": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "license": { "type": ["string", "null"] }
      },
      "description": "Auto-refreshed nightly by scripts/fetch-stats.js for entries with a repo URL. Leave as nulls at submission time."
    },
    "submitted": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Date the entry was first added to the list (YYYY-MM-DD)"
    },
    "status": {
      "type": "string",
      "enum": ["active", "watchlist", "archived"],
      "description": "active = endorsed; watchlist = flagged (stale, early, ToS-risk); archived = upstream archived or no longer maintained"
    }
  }
}
